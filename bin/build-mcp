#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"
swiftc -o "$REPO_ROOT/trivium-mcp-server" "$REPO_ROOT/trivium-mcp-server.swift"
echo "** MCP SERVER BUILD SUCCEEDED **"

swiftc -o "$REPO_ROOT/trivium-permission-hook" "$REPO_ROOT/trivium-permission-hook.swift"
echo "** PERMISSION HOOK BUILD SUCCEEDED **"
