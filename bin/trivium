#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
CONFIGURATION="${CONFIGURATION:-Debug}"
INPUT_DIR="${1:-$(pwd)}"

if ! DIR="$(cd "$INPUT_DIR" 2>/dev/null && pwd -P)"; then
    echo "Directory not found: $INPUT_DIR" >&2
    exit 1
fi

BUILD_SETTINGS="$(
    xcodebuild \
        -project "$REPO_ROOT/Trivium.xcodeproj" \
        -scheme Trivium \
        -configuration "$CONFIGURATION" \
        -showBuildSettings 2>/dev/null
)"
TARGET_BUILD_DIR="$(printf '%s\n' "$BUILD_SETTINGS" | awk -F ' = ' '/^[[:space:]]*TARGET_BUILD_DIR = / { print $2; exit }')"
FULL_PRODUCT_NAME="$(printf '%s\n' "$BUILD_SETTINGS" | awk -F ' = ' '/^[[:space:]]*FULL_PRODUCT_NAME = / { print $2; exit }')"
APP_PATH="${TRIVIUM_APP_PATH:-$TARGET_BUILD_DIR/$FULL_PRODUCT_NAME}"

if [ ! -x "$APP_PATH/Contents/MacOS/Trivium" ]; then
    echo "Trivium.app not found at $APP_PATH. Build it first with $REPO_ROOT/bin/build-app." >&2
    exit 1
fi

exec "$APP_PATH/Contents/MacOS/Trivium" "$DIR"
